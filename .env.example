# Ollama server URL
OLLAMA_URL=http://192.168.1.126:11434

# Polling interval in seconds
POLL_INTERVAL_S=2.0

# History duration in seconds (24 hours)
HISTORY_DURATION_S=86400.0

# Temperature threshold in Celsius
TEMP_THRESHOLD_C=95.0

# Whether to show the temperature threshold line in UI
TEMP_THRESHOLD_VISIBLE=true

# Whether to show the memory junction temperature in UI
MEM_JUNCTION_VISIBLE=true
