Implement `HistoryStore` in src/nmon/history.py. The class must manage in-memory ring buffers for GPU and Ollama snapshots, with automatic flushing to SQLite DB when thresholds are exceeded. Import `GpuSnapshot` from nmon.gpu_monitor, `OllamaSnapshot` from nmon.ollama_monitor, `Settings` from nmon.config, and `DbConnection` from nmon.db.

```python
"""
HistoryStore manages in-memory ring buffers for GPU and Ollama snapshots,
automatically flushing to SQLite DB when thresholds are exceeded.
"""

from collections import deque
from typing import Literal
import time

from nmon.gpu_monitor import GpuSnapshot
from nmon.ollama_monitor import OllamaSnapshot
from nmon.config import Settings
from nmon.db import DbConnection


class HistoryStore:
    """
    In-memory ring buffer for GPU and Ollama snapshots, with periodic DB flush.
    
    Stores snapshots in memory and flushes to SQLite when buffer size exceeds
    a threshold based on history_hours and poll_interval_s from Settings.
    """
    
    def __init__(self, settings: Settings) -> None:
        """
        Initialize HistoryStore with settings.
        
        Args:
            settings: Application settings containing history_hours, poll_interval_s, db_path
        """
        # Initialize in-memory deques for GPU and Ollama snapshots
        self._gpu_snapshots: deque[GpuSnapshot] = deque()
        self._ollama_snapshots: deque[OllamaSnapshot] = deque()
        
        # Store settings for history duration and poll interval
        self._settings = settings
        
        # Load existing data from SQLite DB into in-memory buffers
        # TODO: Implement load_from_db method call here
        
    def add_gpu_samples(self, samples: list[GpuSnapshot]) -> None:
        """
        Add GPU samples to in-memory deque and trim if necessary.
        
        Args:
            samples: List of GpuSnapshot objects to add
        """
        # Append samples to in-memory GPU deque
        self._gpu_snapshots.extend(samples)
        
        # Trim deque to max size based on history_hours and poll_interval
        max_size = int(self._settings.history_hours * 3600 / self._settings.poll_interval_s)
        if len(self._gpu_snapshots) > max_size:
            # Remove oldest elements to maintain size limit
            while len(self._gpu_snapshots) > max_size:
                self._gpu_snapshots.popleft()
        
        # If deque size exceeds threshold, flush to DB
        # TODO: Implement threshold check and flush logic
        
    def add_ollama_sample(self, sample: OllamaSnapshot) -> None:
        """
        Add Ollama sample to in-memory deque and trim if necessary.
        
        Args:
            sample: OllamaSnapshot object to add
        """
        # Append sample to in-memory Ollama deque
        self._ollama_snapshots.append(sample)
        
        # Trim deque to max size based on history_hours and poll_interval
        max_size = int(self._settings.history_hours * 3600 / self._settings.poll_interval_s)
        if len(self._ollama_snapshots) > max_size:
            # Remove oldest elements to maintain size limit
            while len(self._ollama_snapshots) > max_size:
                self._ollama_snapshots.popleft()
        
        # If deque size exceeds threshold, flush to DB
        # TODO: Implement threshold check and flush logic
        
    def gpu_series(self, gpu_index: int, hours: float) -> list[GpuSnapshot]:
        """
        Get GPU snapshots for a specific GPU within a time range.
        
        Args:
            gpu_index: Index of GPU to filter by
            hours: Number of hours to look back
            
        Returns:
            List of GpuSnapshot objects matching criteria
        """
        # Calculate start timestamp from current time and hours
        start_timestamp = time.time() - (hours * 3600)
        
        # Filter in-memory GPU deque for matching gpu_index and timestamp range
        filtered = [
            snap for snap in self._gpu_snapshots
            if snap.gpu_index == gpu_index and snap.timestamp >= start_timestamp
        ]
        
        return filtered
        
    def ollama_series(self, hours: float) -> list[OllamaSnapshot]:
        """
        Get Ollama snapshots within a time range.
        
        Args:
            hours: Number of hours to look back
            
        Returns:
            List of OllamaSnapshot objects matching criteria
        """
        # Calculate start timestamp from current time and hours
        start_timestamp = time.time() - (hours * 3600)
        
        # Filter in-memory Ollama deque for timestamp range
        filtered = [
            snap for snap in self._ollama_snapshots
            if snap.timestamp >= start_timestamp
        ]
        
        return filtered
        
    def gpu_stat(self, gpu_index: int, field: str, hours: float, stat: Literal["max","avg","current"]) -> float | None:
        """
        Compute max/avg/current statistic for a GPU field over a time range.
        
        Args:
            gpu_index: Index of GPU to filter by
            field: Name of field to compute statistic for
            hours: Number of hours to look back
            stat: Type of statistic to compute
            
        Returns:
            Computed statistic value or None if no valid data
        """
        # Retrieve gpu_series for given gpu_index and hours
        series = self.gpu_series(gpu_index, hours)
        
        # Filter series to only include snapshots with non-None values for field
        valid_values = []
        for snap in series:
            value = getattr(snap, field, None)
            if value is not None:
                valid_values.append(value)
        
        if not valid_values:
            return None
            
        # Compute max/avg/current based on stat parameter
        if stat == "max":
            return max(valid_values)
        elif stat == "avg":
            return sum(valid_values) / len(valid_values)
        elif stat == "current":
            return valid_values[-1]  # Return most recent value
        else:
            raise ValueError(f"Unknown stat type: {stat}")
            
    def flush_to_db(self, db: DbConnection) -> None:
        """
        Flush all in-memory snapshots to SQLite database.
        
        Args:
            db: Database connection to flush to
        """
        # Begin DB transaction
        # TODO: Implement transaction handling
        
        # Insert all GPU samples from in-memory deque into gpu_metrics table
        # TODO: Implement GPU snapshot insertion
        
        # Insert all Ollama samples from in-memory deque into ollama_metrics table
        # TODO: Implement Ollama snapshot insertion
        
        # Prune old rows from both tables based on settings.history_hours
        # TODO: Implement pruning logic
        
        # Commit transaction; log warning on failure
        # TODO: Implement error handling and logging
