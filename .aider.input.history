# 2026-04-19 21:14:00.043795
+# Target file: src/nmon/db.py
+# Required imports: sqlite3, time, logging
+# from nmon.gpu_monitor import GpuSnapshot
+# from nmon.ollama_monitor import OllamaSnapshot
+
+# DbConnection = sqlite3.Connection  — type alias; callers own the connection lifetime.
+
+# def init_db(db_path: str) -> None
+#   Open sqlite3.connect(db_path). Execute CREATE TABLE IF NOT EXISTS gpu_metrics (
+#     id INTEGER PRIMARY KEY, gpu_index INTEGER NOT NULL, ts REAL NOT NULL,
+#     temp_c REAL, mem_junc_c REAL, mem_used_mb REAL, power_w REAL).
+#   Execute CREATE TABLE IF NOT EXISTS ollama_metrics (
+#     id INTEGER PRIMARY KEY, ts REAL NOT NULL, gpu_use_pct REAL,
+#     cpu_use_pct REAL, gpu_layers INTEGER, total_layers INTEGER).
+#   Commit and close on success.
+#   On any exception: log with logging.error(), re-raise.
+
+# def prune_old_data(db_path: str, history_hours: int) -> None
+#   Open sqlite3.connect(db_path).
